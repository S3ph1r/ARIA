FROM nvidia/cuda:12.1.1-base-ubuntu22.04

# Installa solo base + Python (nessun PyTorch)
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-dev \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# PyTorch lo installiamo in runtime solo per dev
COPY requirements-light.txt .
RUN pip3 install --no-cache-dir -r requirements-light.txt

# Crea directory logs
RUN mkdir -p /app/logs

EXPOSE 8000

# Comando base - verrà sovrascritto da docker-compose
CMD ["python3", "-c", "print('ARIA Dev Container Ready')"]
.installed.cfg
*.egg

# Virtual Environments & Conda
envs/
venv/
.venv/
conda-bld/

# ARIA Specific Assets (Modelli e Voci pesanti)
data/models/*/
data/voices/*/
data/outputs/*/
data/models/*.bin
data/models/*.pth
data/models/*.onnx
data/voices/**/*.wav
data/voices/**/*.mp3
data/voices/**/*.ref
!data/voices/.gitkeep
!data/models/.gitkeep
!data/outputs/.gitkeep

# Local Configurations (SENSITIVE / MACHINE SPECIFIC)
node_settings.json
.env

# Logs and Archives
logs/
archive/
*.log

